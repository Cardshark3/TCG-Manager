<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TCG_Manager.Views.CardDetailsPage"
             Title="CardDetailsPage"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout HorizontalOptions="Center">
            <Image x:Name="CardImage" HeightRequest="350" HorizontalOptions="Center" Margin="0,30,0,0" ></Image>
            <Label x:Name="CardName" HorizontalOptions="Center" FontSize="Large" Margin="0,20,0,0"></Label>
            <Label x:Name="CardPack" HorizontalOptions="Center" FontSize="Medium" Margin="0,10,0,0"></Label>
            <Label x:Name="CardAmount" HorizontalOptions="Center" FontSize="Medium" Margin="0,10,0,0"></Label>
            <Grid x:Name="AveragePriceGrid">
                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                </Grid.ColumnDefinitions>
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>