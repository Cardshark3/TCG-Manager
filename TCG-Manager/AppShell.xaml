<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TCG_Manager.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:TCG_Manager"
    xmlns:pages="clr-namespace:TCG_Manager.Views"
    Title="TCG_Manager">

    <TabBar>
        <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage"
        Shell.NavBarIsVisible="False"/>
        <ShellContent
        Title="Add Card"
        ContentTemplate="{DataTemplate pages:AddCardPage}"
        Route="AddCardPage"
        Shell.NavBarIsVisible="False"/>
    </TabBar>

</Shell>
